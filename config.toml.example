[gmail]
credentials_file = "~/.mailfiler/credentials.json"
token_file = "~/.mailfiler/token.json"
user_email = ""  # Your Gmail address, used for direct-to scoring
poll_interval_minutes = 5
max_emails_per_run = 50

[llm]
provider = "anthropic"       # "anthropic", "lmstudio", or leave blank for stub
model = "claude-haiku-4-5"   # For lmstudio: "qwen3-30b-a3b-2507" (good for 32GB Mac)
max_tokens = 500
timeout_seconds = 10
base_url = ""                # For lmstudio: "http://localhost:1234/v1"

[rules]
allow_trash = false
confidence_threshold = 0.85
llm_threshold = 0.6
confirmation_days = 7

[vip_senders]
emails = []

[vip_domains]
domains = []

[blocked_senders]
emails = []

[labels]
prefix = "mailfiler"
# inbox and archived are required; add or remove others as needed.

[[labels.categories]]
name = "inbox"
description = "Important emails that need attention"

[[labels.categories]]
name = "newsletter"
description = "Subscription content, digests, editorial emails"

[[labels.categories]]
name = "marketing"
description = "Promotional and sales emails"

[[labels.categories]]
name = "github"
description = "GitHub notifications"

[[labels.categories]]
name = "jira"
description = "Jira notifications"

[[labels.categories]]
name = "automated"
description = "Auto-generated system messages"

[[labels.categories]]
name = "receipts"
description = "Purchase receipts, invoices, shipping confirmations"

[[labels.categories]]
name = "calendar"
description = "Calendar invites and event updates"

[[labels.categories]]
name = "security"
description = "Security alerts, verification codes, sign-in notifications"

[[labels.categories]]
name = "finance"
description = "Bank statements, invoices, tax documents"

[[labels.categories]]
name = "archived"
description = "General archive for low-priority items"

[database]
path = "~/.mailfiler/mailfiler.db"

[daemon]
pid_file = "~/.mailfiler/mailfiler.pid"
run_mode = "observe"
