[gmail]
credentials_file = "~/.mailfiler/credentials.json"
token_file = "~/.mailfiler/token.json"
user_email = ""  # Your Gmail address, used for direct-to scoring
poll_interval_minutes = 5
max_emails_per_run = 50

[llm]
provider = "anthropic"       # "anthropic", "lmstudio", or leave blank for stub
model = "claude-haiku-4-5"   # For lmstudio: "qwen3-30b-a3b-2507" (good for 32GB Mac)
max_tokens = 500
timeout_seconds = 10
base_url = ""                # For lmstudio: "http://localhost:1234/v1"

[rules]
allow_trash = false
confidence_threshold = 0.85
llm_threshold = 0.6
confirmation_days = 7

[vip_senders]
emails = []

[vip_domains]
domains = []

[blocked_senders]
emails = []

[labels]
prefix = "mailfiler"

[database]
path = "~/.mailfiler/mailfiler.db"

[daemon]
pid_file = "~/.mailfiler/mailfiler.pid"
run_mode = "observe"
